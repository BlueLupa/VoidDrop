{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoidDrop",
  "version": "1.0.1",
  "identifier": "com.stefan.voiddrop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VoidDrop",
        "width": 1200,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "hiddenTitle": true,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' asset: http://asset.localhost blob:; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; worker-src blob: 'self'; script-src 'self' blob: 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  }
}