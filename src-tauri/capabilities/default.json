{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "core:window:allow-set-always-on-top",
    {
      "identifier": "fs:default",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    "fs:allow-copy-file",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    }
  ]
}